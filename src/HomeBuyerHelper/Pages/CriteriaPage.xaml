<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HomeBuyerHelper.ViewModels"
             xmlns:models="clr-namespace:HomeBuyerHelper.Core.Models;assembly=HomeBuyerHelper.Core"
             x:Class="HomeBuyerHelper.Pages.CriteriaPage"
             x:DataType="vm:CriteriaViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16">

        <!-- Weight Summary Header -->
        <Frame Grid.Row="0" Style="{StaticResource CardFrame}" Margin="0,0,0,16" Padding="16,12">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="16">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="{Binding Criteria.Count, StringFormat='{0} Criteria'}"
                           Style="{StaticResource Title}"/>
                    <Label Text="Tap to edit, swipe to delete"
                           Style="{StaticResource Caption}"
                           TextColor="{StaticResource Gray500}"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="End">
                    <Label Text="{Binding TotalWeight, StringFormat='{0}%'}"
                           Style="{StaticResource Title}"
                           TextColor="{Binding TotalWeightColor}"
                           HorizontalTextAlignment="End"/>
                    <Label Text="Total Weight"
                           Style="{StaticResource Caption}"
                           TextColor="{StaticResource Gray500}"
                           HorizontalTextAlignment="End"/>
                </VerticalStackLayout>
                <Button Grid.Column="2"
                        Text="Rebalance"
                        Command="{Binding RebalanceCommand}"
                        IsVisible="{Binding NeedsRebalancing}"
                        Style="{StaticResource TextButton}"
                        VerticalOptions="Center"/>
            </Grid>
        </Frame>

        <!-- Criteria List -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Criteria}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" Spacing="16" Padding="32">
                    <Label Text="No Criteria Yet"
                           Style="{StaticResource Title}"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Add your first criterion to start evaluating properties. Criteria help you score what matters most to you."
                           Style="{StaticResource Body}"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource Gray500}"/>
                    <Button Text="Add Criterion"
                            Command="{Binding AddNewCommand}"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:EvaluationCriterion">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete"
                                           BackgroundColor="{StaticResource Error}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CriteriaViewModel}}, Path=DeleteCriterionCommand}"
                                           CommandParameter="{Binding}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Frame Style="{StaticResource CardFrame}" Margin="0,4">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CriteriaViewModel}}, Path=EditCriterionCommand}"
                                    CommandParameter="{Binding}"/>
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12">
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Name}"
                                       Style="{StaticResource Subtitle}"
                                       LineBreakMode="TailTruncation"/>
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Weight, StringFormat='{0}%'}"
                                       Style="{StaticResource Body}"
                                       TextColor="{StaticResource Primary}"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"/>
                                <Image Grid.Row="0" Grid.Column="2"
                                       Source="lock.png"
                                       HeightRequest="16"
                                       WidthRequest="16"
                                       IsVisible="{Binding IsWeightLocked}"
                                       VerticalOptions="Center"/>
                                <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Spacing="8">
                                    <Frame BackgroundColor="{StaticResource SurfaceVariant}"
                                           Padding="6,2"
                                           CornerRadius="4"
                                           BorderColor="Transparent">
                                        <Label Text="{Binding Category}"
                                               Style="{StaticResource Caption}"
                                               TextColor="{StaticResource OnSurfaceVariant}"/>
                                    </Frame>
                                    <Label Text="{Binding IsSystemSuggested, Converter={StaticResource SystemSuggestedConverter}}"
                                           Style="{StaticResource Caption}"
                                           TextColor="{StaticResource Gray500}"
                                           VerticalOptions="Center"
                                           IsVisible="{Binding IsSystemSuggested}"/>
                                </HorizontalStackLayout>
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- FAB for adding new criterion -->
        <Button Grid.Row="2"
                Text="+ Add Criterion"
                Command="{Binding AddNewCommand}"
                Style="{StaticResource PrimaryButton}"
                Margin="0,16,0,0"
                AutomationProperties.Name="Add new criterion"/>

        <!-- Loading -->
        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

    </Grid>

</ContentPage>
