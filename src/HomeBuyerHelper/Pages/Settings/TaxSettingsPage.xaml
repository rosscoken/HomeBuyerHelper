<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HomeBuyerHelper.ViewModels.Settings"
             x:Class="HomeBuyerHelper.Pages.Settings.TaxSettingsPage"
             x:DataType="vm:TaxSettingsViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Label Text="Let's understand your tax situation"
                   Style="{StaticResource Title}"/>
            <Label Text="Used to estimate taxes on down payment funding sources. Estimates only — not tax advice."
                   Style="{StaticResource Caption}" TextColor="{StaticResource Gray500}"/>

            <Label Text="Filing Status" Style="{StaticResource Caption}" TextColor="{StaticResource Gray500}"/>
            <Picker ItemsSource="{Binding FilingStatusNames}"
                    SelectedIndex="{Binding FilingStatusIndex}"
                    AutomationProperties.Name="Tax filing status"/>

            <Label Text="Estimated Taxable Income" Style="{StaticResource Caption}" TextColor="{StaticResource Gray500}"/>
            <Entry Text="{Binding EstimatedTaxableIncome}"
                   Keyboard="Numeric"
                   Placeholder="0"
                   AutomationProperties.Name="Estimated taxable income"/>

            <Label Text="State Marginal Tax Rate (%)" Style="{StaticResource Caption}" TextColor="{StaticResource Gray500}"/>
            <Entry Text="{Binding StateMarginalTaxRate}"
                   Keyboard="Numeric"
                   Placeholder="0 for no-income-tax states"
                   AutomationProperties.Name="State marginal tax rate"/>

            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Your estimated brackets" Style="{StaticResource Subtitle}"/>
                    <Label Text="{Binding FederalMarginalRate, StringFormat='Federal marginal rate: {0:F0}%'}"
                           Style="{StaticResource Body}"/>
                    <Label Text="{Binding CapitalGainsRate, StringFormat='Long-term capital gains rate: {0:F0}%'}"
                           Style="{StaticResource Body}"/>
                </VerticalStackLayout>
            </Frame>

            <Label Text="{Binding ErrorMessage}"
                   IsVisible="{Binding HasError}"
                   TextColor="{StaticResource Error}"
                   Style="{StaticResource Body}"/>

            <Button Text="Save"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButton}"
                    AutomationProperties.Name="Save tax settings"/>
            <Button Text="Cancel"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource TextButton}"
                    AutomationProperties.Name="Cancel"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
