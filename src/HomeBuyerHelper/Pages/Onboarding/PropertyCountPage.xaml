<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HomeBuyerHelper.ViewModels.Onboarding"
             x:Class="HomeBuyerHelper.Pages.Onboarding.PropertyCountPage"
             x:DataType="vm:PropertyCountViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="24">

        <!-- Progress Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="16">
            <ProgressBar Progress="0.2" ProgressColor="{StaticResource Primary}" HeightRequest="4"/>
            <Label Text="Step 2 of 7" Style="{StaticResource Caption}" HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <!-- Content -->
        <ScrollView Grid.Row="1" VerticalOptions="Center">
            <VerticalStackLayout Spacing="24" Padding="0,24">

                <Label Text="How many properties are you currently considering?"
                       Style="{StaticResource Headline}"
                       HorizontalTextAlignment="Center"/>

                <!-- Option Buttons -->
                <VerticalStackLayout Spacing="12">
                    <RadioButton Content="Just starting my search (0-1)"
                                 IsChecked="{Binding IsJustStartingSelected}"
                                 GroupName="PropertyCount"
                                 Style="{StaticResource RadioButtonCard}"/>

                    <RadioButton Content="A few options (2-3)"
                                 IsChecked="{Binding IsFewOptionsSelected}"
                                 GroupName="PropertyCount"
                                 Style="{StaticResource RadioButtonCard}"/>

                    <RadioButton Content="Several to compare (4+)"
                                 IsChecked="{Binding IsSeveralSelected}"
                                 GroupName="PropertyCount"
                                 Style="{StaticResource RadioButtonCard}"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Navigation -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="16">
            <Button Grid.Column="0"
                    Text="Back"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource OutlineButton}"
                    HeightRequest="50"/>

            <Button Grid.Column="1"
                    Text="Continue"
                    Command="{Binding ContinueCommand}"
                    IsEnabled="{Binding HasSelection}"
                    Style="{StaticResource PrimaryButton}"
                    HeightRequest="50"/>
        </Grid>

    </Grid>

</ContentPage>
