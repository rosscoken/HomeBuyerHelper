<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HomeBuyerHelper.ViewModels.Budget"
             xmlns:models="clr-namespace:HomeBuyerHelper.Core.Models;assembly=HomeBuyerHelper.Core"
             x:Class="HomeBuyerHelper.Pages.Budget.IncomeSetupPage"
             x:DataType="vm:IncomeSetupViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header Summary -->
        <Frame Grid.Row="0" Style="{StaticResource CardFrame}" Margin="16,16,16,8" Padding="16">
            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*" RowSpacing="8">
                <Label Text="Total Monthly Income"
                       Style="{StaticResource Caption}"
                       TextColor="{StaticResource Gray500}"/>
                <Label Grid.Column="1"
                       Text="Reliable Monthly"
                       Style="{StaticResource Caption}"
                       TextColor="{StaticResource Gray500}"
                       HorizontalTextAlignment="End"/>

                <Label Grid.Row="1"
                       Text="{Binding TotalMonthlyIncome, StringFormat='${0:N0}'}"
                       Style="{StaticResource Title}"
                       TextColor="{StaticResource Primary}"/>
                <Label Grid.Row="1" Grid.Column="1"
                       Text="{Binding ReliableMonthlyIncome, StringFormat='${0:N0}'}"
                       Style="{StaticResource Title}"
                       TextColor="{StaticResource Success}"
                       HorizontalTextAlignment="End"/>

                <Label Grid.Row="2" Grid.ColumnSpan="2"
                       Text="{Binding TotalAnnualIncome, StringFormat='${0:N0}/year'}"
                       Style="{StaticResource Caption}"
                       TextColor="{StaticResource Gray400}"/>
            </Grid>
        </Frame>

        <!-- Income List or Edit Form -->
        <Grid Grid.Row="1">

            <!-- Income List View -->
            <ScrollView IsVisible="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}">
                <VerticalStackLayout Padding="16,8" Spacing="8">

                    <Label Text="Your Income Sources"
                           Style="{StaticResource Subtitle}"
                           IsVisible="{Binding IncomeSources.Count, Converter={StaticResource IntToBoolConverter}}"/>

                    <Label Text="No income sources configured yet. Add your first income source to get started."
                           Style="{StaticResource Body}"
                           TextColor="{StaticResource Gray400}"
                           HorizontalTextAlignment="Center"
                           Margin="0,40"
                           IsVisible="{Binding IncomeSources.Count, Converter={StaticResource IntToInvertedBoolConverter}}"/>

                    <CollectionView ItemsSource="{Binding IncomeSources}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:IncomeSource">
                                <Frame Style="{StaticResource CardFrame}" Margin="0,4" Padding="12">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                                        <Label Text="{Binding Name}"
                                               Style="{StaticResource Subtitle}"
                                               FontAttributes="Bold"/>

                                        <HorizontalStackLayout Grid.Column="1" Spacing="8">
                                            <Button Text="Edit"
                                                    Style="{StaticResource TextButton}"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:IncomeSetupViewModel}}, Path=StartEditIncomeCommand}"
                                                    CommandParameter="{Binding .}"
                                                    HeightRequest="32"
                                                    Padding="8,0"/>
                                            <Button Text="Delete"
                                                    Style="{StaticResource TextButton}"
                                                    TextColor="{StaticResource Error}"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:IncomeSetupViewModel}}, Path=DeleteIncomeCommand}"
                                                    CommandParameter="{Binding .}"
                                                    HeightRequest="32"
                                                    Padding="8,0"/>
                                        </HorizontalStackLayout>

                                        <Label Grid.Row="1"
                                               Text="{Binding MonthlyGrossIncome, StringFormat='${0:N0}/month'}"
                                               Style="{StaticResource Body}"
                                               TextColor="{StaticResource Primary}"
                                               FontAttributes="Bold"/>

                                        <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="8">
                                            <Frame BackgroundColor="{StaticResource Gray100}"
                                                   Padding="6,2"
                                                   CornerRadius="4"
                                                   BorderColor="Transparent">
                                                <Label Text="{Binding IncomeType}"
                                                       Style="{StaticResource Caption}"/>
                                            </Frame>
                                            <Frame BackgroundColor="{StaticResource Gray100}"
                                                   Padding="6,2"
                                                   CornerRadius="4"
                                                   BorderColor="Transparent">
                                                <Label Text="{Binding Frequency}"
                                                       Style="{StaticResource Caption}"/>
                                            </Frame>
                                            <Frame BackgroundColor="{Binding IsReliable, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Success|Gray200'}"
                                                   Padding="6,2"
                                                   CornerRadius="4"
                                                   BorderColor="Transparent"
                                                   IsVisible="{Binding IsReliable}">
                                                <Label Text="Reliable"
                                                       Style="{StaticResource Caption}"
                                                       TextColor="{StaticResource White}"/>
                                            </Frame>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Edit Form -->
            <ScrollView IsVisible="{Binding IsEditing}">
                <VerticalStackLayout Padding="16" Spacing="16">

                    <Label Text="{Binding SelectedIncome, Converter={StaticResource NullToBoolConverter}, ConverterParameter='Edit Income|Add New Income'}"
                           Style="{StaticResource Title}"/>

                    <!-- Name -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Income Source Name" Style="{StaticResource Caption}"/>
                        <Entry Text="{Binding EditName}"
                               Placeholder="e.g., Primary Salary"
                               AutomationProperties.Name="Income Source Name"/>
                    </VerticalStackLayout>

                    <!-- Gross Amount -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Gross Amount (before taxes)" Style="{StaticResource Caption}"/>
                        <Entry Text="{Binding EditGrossAmount}"
                               Keyboard="Numeric"
                               Placeholder="0.00"
                               AutomationProperties.Name="Gross Amount"/>
                    </VerticalStackLayout>

                    <!-- Frequency -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Payment Frequency" Style="{StaticResource Caption}"/>
                        <Picker ItemsSource="{Binding FrequencyOptions}"
                                SelectedItem="{Binding EditFrequency}"
                                AutomationProperties.Name="Payment Frequency"/>
                    </VerticalStackLayout>

                    <!-- Income Type -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Income Type" Style="{StaticResource Caption}"/>
                        <Picker ItemsSource="{Binding IncomeTypeOptions}"
                                SelectedItem="{Binding EditIncomeType}"
                                AutomationProperties.Name="Income Type"/>
                    </VerticalStackLayout>

                    <!-- Is Reliable -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Reliable Income" Style="{StaticResource Subtitle}"/>
                            <Label Text="Check if this income is guaranteed and consistent."
                                   Style="{StaticResource Caption}"
                                   TextColor="{StaticResource Gray400}"/>
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding EditIsReliable}"
                                AutomationProperties.Name="Reliable Income Toggle"/>
                    </Grid>

                    <!-- Notes -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Notes (optional)" Style="{StaticResource Caption}"/>
                        <Editor Text="{Binding EditNotes}"
                                Placeholder="Add any notes about this income..."
                                HeightRequest="80"
                                AutomationProperties.Name="Notes"/>
                    </VerticalStackLayout>

                    <!-- Error Message -->
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource Error}"
                           IsVisible="{Binding HasError}"
                           HorizontalTextAlignment="Center"/>

                    <!-- Form Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Text="Cancel"
                                Command="{Binding CancelEditCommand}"
                                Style="{StaticResource OutlineButton}"/>
                        <Button Grid.Column="1"
                                Text="Save"
                                Command="{Binding SaveIncomeCommand}"
                                Style="{StaticResource PrimaryButton}"/>
                    </Grid>

                </VerticalStackLayout>
            </ScrollView>

        </Grid>

        <!-- Bottom Buttons -->
        <VerticalStackLayout Grid.Row="2"
                             Padding="16"
                             Spacing="8"
                             IsVisible="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}">
            <Button Text="Add Income Source"
                    Command="{Binding StartAddIncomeCommand}"
                    Style="{StaticResource PrimaryButton}"/>
            <Button Text="Back"
                    Command="{Binding GoBackCommand}"
                    Style="{StaticResource OutlineButton}"/>
        </VerticalStackLayout>

        <!-- Loading Indicator -->
        <ActivityIndicator Grid.RowSpan="3"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>

    </Grid>

</ContentPage>
