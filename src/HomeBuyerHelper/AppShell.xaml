<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HomeBuyerHelper.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:HomeBuyerHelper.Pages"
    xmlns:budget="clr-namespace:HomeBuyerHelper.Pages.Budget"
    Shell.FlyoutBehavior="Disabled"
    Title="HomeBuyerHelper">

    <!-- Main Tab Navigation -->
    <TabBar>
        <ShellContent
            Title="Dashboard"
            ContentTemplate="{DataTemplate pages:DashboardPage}"
            Route="Dashboard"
            Icon="home_icon.png" />

        <ShellContent
            Title="Properties"
            ContentTemplate="{DataTemplate pages:PropertyListPage}"
            Route="Properties"
            Icon="property_icon.png" />

        <ShellContent
            Title="Compare"
            ContentTemplate="{DataTemplate pages:ComparisonPage}"
            Route="Comparison"
            Icon="compare_icon.png" />

        <ShellContent
            Title="Criteria"
            ContentTemplate="{DataTemplate pages:CriteriaPage}"
            Route="Criteria"
            Icon="criteria_icon.png" />

        <ShellContent
            Title="Budget"
            ContentTemplate="{DataTemplate budget:BudgetPage}"
            Route="Budget"
            Icon="budget_icon.png" />
    </TabBar>

</Shell>
