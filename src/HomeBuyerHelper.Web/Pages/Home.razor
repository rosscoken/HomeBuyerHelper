@page "/"
@inject IPropertyService PropertyService
@inject ICriteriaRepository CriteriaRepository
@inject IPlanService PlanService
@inject IUserPreferencesRepository PreferencesRepository
@inject NavigationManager Nav

<PageTitle>HomeBuyerHelper</PageTitle>

<h1>Dashboard</h1>
<p class="page-sub">Compare homes on what matters to you. Everything stays in your browser.</p>

@if (_loaded)
{
    @if (_criteriaCount == 0)
    {
        <h2>Get started in three steps</h2>
        <div class="steps">
            <a class="step" href="criteria">
                <span class="step-num">1</span>
                <span>
                    <strong>Set up your evaluation criteria</strong>
                    <span>Define what matters — or apply a starter template.</span>
                </span>
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </a>
            <a class="step" href="properties">
                <span class="step-num">2</span>
                <span>
                    <strong>Add the properties you're considering</strong>
                    <span>Capture price, size, commute — then score each one.</span>
                </span>
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </a>
            <a class="step" href="compare">
                <span class="step-num">3</span>
                <span>
                    <strong>See the comparison and your budget</strong>
                    <span>Side-by-side scores, true total cost, and cash flow.</span>
                </span>
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </a>
        </div>
    }
    else if (_rankings.Count == 0)
    {
        <div class="empty-state">
            <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <p>Criteria are set up. <a href="properties">Add your first property</a> to start comparing.</p>
        </div>
    }
    else
    {
        <h2>Property Rankings</h2>
        <div class="score-list">
            @foreach (var ranking in _rankings)
            {
                <div class="score-item">
                    <div class="score-item-head">
                        <span class="rank-chip r@(ranking.Rank)">@ranking.Rank</span>
                        <strong>@ranking.Property.Nickname</strong>
                        <span class="item-actions"><span class="badge brand">@ranking.Property.EffectivePrice.ToString("C0")</span></span>
                    </div>
                    <span class="score-cell">
                        <span class="progress @(ranking.ScorePercentage >= 80 ? "green" : ranking.ScorePercentage >= 50 ? "" : "amber")">
                            <i style="width:@(ranking.ScorePercentage.ToString("F0"))%"></i>
                        </span>
                        <strong>@ranking.ScorePercentage.ToString("F0")%</strong>
                    </span>
                </div>
            }
        </div>
    }

    @if (_plan != null)
    {
        <h2>Your Plan</h2>
        <div class="card">
            <div class="row">
                <span>
                    <label>Target property</label>
                    <strong>@_plan.Property.Nickname</strong>
                </span>
                <span>
                    <label>Offer</label>
                    <strong>@_plan.Offer.Name</strong> <span class="muted">@_plan.Offer.OfferPrice.ToString("C0")</span>
                </span>
                <span>
                    <label>Total monthly cost</label>
                    <strong>@_plan.Evaluation.TotalMonthlyCost.ToString("C0")/mo</strong>
                </span>
                @if (_plan.RealisticAffordability is AffordabilityAssessment zone)
                {
                    <span>
                        <label>Affordability (Realistic)</label>
                        <span class="badge @ZoneBadgeClass(zone.Zone)">@zone.ZoneLabel</span>
                    </span>
                }
            </div>
            <div class="row mt-12">
                <span>
                    <label>Cash to close</label>
                    <strong>@_plan.Evaluation.CashToClose.ToString("C0")</strong>
                </span>
                <span>
                    <label>@(_plan.FundingSurplus >= 0 ? "Funding surplus" : "Funding shortfall")</label>
                    <span class="badge @(_plan.FundingSurplus >= 0 ? "ok" : "warn")">
                        @(_plan.FundingSurplus >= 0 ? "+" : "−")@Math.Abs(_plan.FundingSurplus).ToString("C0")
                    </span>
                </span>
            </div>
            <div class="row mt-12">
                <a class="module-link" href="offers">Adjust offer
                    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
                <a class="module-link" href="budget">See it in your budget
                    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
            </div>
        </div>
    }

    <h2>Plan your purchase</h2>
    <div class="grid-3">
        <a class="module-card" href="budget">
            <span class="module-icon violet">
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
            </span>
            <h3>Budget Planner</h3>
            <p>Income scenarios, expenses, and a 24-month cash flow projection.</p>
            <span class="module-link">Open Budget
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
        </a>
        <a class="module-card" href="funding">
            <span class="module-icon green">
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><line x1="12" y1="6" x2="12" y2="8"/><line x1="12" y1="16" x2="12" y2="18"/></svg>
            </span>
            <h3>Down Payment Funding</h3>
            <p>Plan funding sources and estimate the taxes for each.</p>
            <span class="module-link">Open Funding
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
        </a>
        <a class="module-card" href="rent-vs-buy">
            <span class="module-icon amber">
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 3h5v5"/><path d="M8 21H3v-5"/><path d="M21 3 3 21"/></svg>
            </span>
            <h3>Rent vs. Buy</h3>
            <p>Year-by-year wealth comparison with a breakeven point.</p>
            <span class="module-link">Open Calculator
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
        </a>
        <a class="module-card" href="offers">
            <span class="module-icon violet">
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.1 2.1 0 0 1 3 3L12 15l-4 1 1-4Z"/></svg>
            </span>
            <h3>Offer Planner</h3>
            <p>Structure offers and see cash-to-close for each scenario.</p>
            <span class="module-link">Open Offers
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
        </a>
        <a class="module-card" href="settings">
            <span class="module-icon amber">
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            </span>
            <h3>Settings</h3>
            <p>Loan defaults, cost assumptions, and commute value.</p>
            <span class="module-link">Open Settings
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
        </a>
        <a class="module-card" href="scenarios">
            <span class="module-icon amber">
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </span>
            <h3>Scenarios</h3>
            <p>See what changes if you wait — savings, market drift, and rent while you save.</p>
            <span class="module-link">Open Scenarios
                <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
        </a>
    </div>
}

@code {
    private bool _loaded;
    private int _criteriaCount;
    private IReadOnlyList<PropertyRanking> _rankings = Array.Empty<PropertyRanking>();
    private PlanSnapshot? _plan;

    protected override async Task OnInitializedAsync()
    {
        _criteriaCount = await CriteriaRepository.GetCountAsync();

        if (_criteriaCount == 0)
        {
            var preferences = await PreferencesRepository.GetAsync();
            if (!preferences.HasCompletedOnboarding)
            {
                Nav.NavigateTo("welcome");
                return;
            }
        }

        _rankings = await PropertyService.GetPropertyRankingsAsync();
        _plan = await PlanService.GetSnapshotAsync();
        _loaded = true;
    }

    private static string ZoneBadgeClass(AffordabilityZone zone) => zone switch
    {
        AffordabilityZone.Comfortable => "ok",
        AffordabilityZone.Stretching => "brand",
        _ => "warn"
    };
}
