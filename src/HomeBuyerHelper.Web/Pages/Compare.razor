@page "/compare"
@inject IPropertyService PropertyService
@inject ICriteriaRepository CriteriaRepository
@inject ITrueTotalCostService TrueTotalCostService
@inject IUserPreferencesRepository PreferencesRepository

<PageTitle>Compare · HomeBuyerHelper</PageTitle>

<div class="row" style="justify-content:space-between; align-items:start">
    <div>
        <h1>Comparison</h1>
        <p class="page-sub">Side-by-side weighted scores and the true monthly cost of each home.</p>
    </div>
    <a href="report"><button type="button" class="secondary sm">Printable report</button></a>
</div>

@if (_loaded && _results.Count < 2)
{
    <div class="empty-state">
        <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        <p>Add and score at least two <a href="properties">properties</a> to compare them side by side.</p>
    </div>
}
else if (_loaded)
{
    <h2>Scores by Criterion</h2>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Criterion (Weight)</th>
                    @foreach (var result in _results) { <th style="text-align:center">@result.Property.Nickname</th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var criterion in _criteria)
                {
                    <tr>
                        <td>@criterion.Name <span class="muted">(@criterion.Weight%)</span></td>
                        @foreach (var result in _results)
                        {
                            var score = result.Scores.FirstOrDefault(s => s.CriterionId == criterion.Id);
                            @if (score == null)
                            {
                                <td class="muted" style="text-align:center">–</td>
                            }
                            else
                            {
                                <td style="text-align:center"><span class="score-pill @ScoreClass(score.Score)">@score.Score</span></td>
                            }
                        }
                    </tr>
                }
                <tr class="total-row">
                    <td><strong>Total Score</strong></td>
                    @foreach (var result in _results)
                    {
                        <td style="text-align:center"><strong>@result.ScorePercentage.ToString("F0")%</strong></td>
                    }
                </tr>
            </tbody>
        </table>
    </div>
    <p class="muted">
        <span class="score-pill good">8–10</span> great ·
        <span class="score-pill mid">5–7</span> okay ·
        <span class="score-pill bad">1–4</span> poor
    </p>

    <h2>True Total Cost</h2>
    <p class="muted">Housing + utilities + the monetized value of commute time.</p>
    <p class="muted">Commute time valued at @_preferences?.TimeValueHourlyRate.ToString("C0")/hr × @_preferences?.WorkdaysPerMonth workdays/mo — <a href="settings">edit</a></p>
    <div class="table-wrap">
        <table>
            <thead>
                <tr><th>Property</th><th class="num">Housing/mo</th><th class="num">Commute/mo</th><th class="num">Total/mo</th><th class="num">30-Year</th></tr>
            </thead>
            <tbody>
                @foreach (var (result, cost) in _trueCosts)
                {
                    <tr>
                        <td>
                            <strong>@result.Property.Nickname</strong>
                            @if (cost == _lowestCost) { <span class="badge ok ml-8">Lowest</span> }
                        </td>
                        <td class="num">@cost.MonthlyHousing.ToString("C0")</td>
                        <td class="num">@cost.MonthlyCommuteValue.ToString("C0")</td>
                        <td class="num"><strong>@cost.MonthlyTotal.ToString("C0")</strong></td>
                        <td class="num">@cost.ThirtyYearTotal.ToString("C0")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private bool _loaded;
    private IReadOnlyList<EvaluationCriterion> _criteria = Array.Empty<EvaluationCriterion>();
    private List<PropertyComparisonResult> _results = new();
    private List<(PropertyComparisonResult Result, TrueTotalCost Cost)> _trueCosts = new();
    private TrueTotalCost? _lowestCost;
    private UserPreferences? _preferences;

    protected override async Task OnInitializedAsync()
    {
        _criteria = await CriteriaRepository.GetAllAsync();
        var properties = await PropertyService.GetPropertiesWithScoresAsync();
        _results = (await PropertyService.ComparePropertiesAsync(properties.Select(p => p.Id))).ToList();

        var preferences = await PreferencesRepository.GetAsync();
        _preferences = preferences;
        _trueCosts = _results
            .Select(result => (result, TrueTotalCostService.Calculate(result.Property, preferences)))
            .ToList();
        _lowestCost = _trueCosts
            .Where(t => t.Item2.MonthlyTotal > 0)
            .OrderBy(t => t.Item2.MonthlyTotal)
            .Select(t => t.Item2)
            .FirstOrDefault();

        _loaded = true;
    }

    private static string ScoreClass(int score) =>
        score >= 8 ? "good" : score >= 5 ? "mid" : "bad";
}
