@page "/criteria"
@inject ICriteriaRepository CriteriaRepository
@inject IWeightBalancingService WeightBalancingService

<PageTitle>Criteria · HomeBuyerHelper</PageTitle>

<h1>Evaluation Criteria</h1>
<p class="page-sub">Define what matters and how much. Weights should total 100%.</p>

<div class="card">
    <h2>Start from a template</h2>
    @if (_confirmingTemplate)
    {
        <div class="row">
            <span class="muted">This replaces your @_criteria.Count current criteria.</span>
            <button class="danger" @onclick="ApplyTemplateAsync">Replace</button>
            <button class="secondary" @onclick="() => _confirmingTemplate = false">Cancel</button>
        </div>
    }
    else
    {
        <div class="row">
            <span>
                <label>Template</label>
                <select @bind="_selectedTemplate">
                    @foreach (var name in HomeBuyerHelper.Core.Data.CommonCriteria.Templates.Keys)
                    {
                        <option value="@name">@name</option>
                    }
                </select>
            </span>
            <button class="secondary" @onclick="OnApplyTemplateClick">Apply Template</button>
        </div>
        <p class="muted mb-0">Applying replaces your current criteria.</p>
    }
</div>

@if (_editing != null)
{
    <div class="card">
        <h2>@(_editing.Id == 0 ? "Add Criterion" : $"Edit: {_editing.Name}")</h2>
        <div class="row">
            <span><label>Name *</label><input @bind="_editing.Name" placeholder="e.g. Kitchen quality" /></span>
            <span>
                <label>Category</label>
                <select @bind="_editing.Category">
                    @foreach (var category in Enum.GetValues<CriterionCategory>())
                    {
                        <option value="@category">@category</option>
                    }
                </select>
            </span>
        </div>
        <div class="row mt-12">
            <span class="grow">
                <label>Weight — <span class="badge brand">@_editing.Weight%</span></label>
                <input type="range" min="1" max="50" step="1"
                       @bind="_editing.Weight" @bind:event="oninput"
                       aria-label="Weight percent" />
            </span>
        </div>
        <div class="row mt-12">
            <span class="grow"><label>What does a 1 look like?</label><input @bind="_editing.ScoreAnchorLow" /></span>
            <span class="grow"><label>What does a 10 look like?</label><input @bind="_editing.ScoreAnchorHigh" /></span>
        </div>
        @if (_error != null) { <p class="error-text">@_error</p> }
        <div class="row mt-14">
            <button @onclick="SaveAsync">Save Criterion</button>
            <button class="secondary" @onclick="() => _editing = null">Cancel</button>
        </div>
    </div>
}
else
{
    <button @onclick="StartAdd">
        <svg aria-hidden="true" focusable="false" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
        Add Criterion
    </button>
}

<h2>
    Your Criteria
    <span class="badge @(_totalWeight == 100 ? "ok" : "warn")">
        @if (_totalWeight == 100)
        {
            <svg aria-hidden="true" focusable="false" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        }
        Total: @_totalWeight%
    </span>
    @if (_totalWeight != 100 && _criteria.Count > 0)
    {
        <button class="secondary sm" @onclick="RebalanceAsync">Auto-balance to 100%</button>
    }
</h2>

@if (_criteria.Any(c => c.Weight > 40))
{
    <p class="muted">Criteria over 40% dominate the ranking — consider rebalancing.</p>
}

@if (_criteria.Count == 0)
{
    <div class="empty-state">
        <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>
        <p>No criteria yet — apply a template above or add your own.</p>
    </div>
}
else
{
    <div class="score-list">
        @foreach (var criterion in _criteria)
        {
            <div class="score-item criteria-item">
                <div class="score-item-head">
                    <strong>@criterion.Name</strong>
                    <span class="chip">@criterion.Category</span>
                    @if (criterion.Weight > 40)
                    {
                        <span class="badge warn">Heavy</span>
                    }
                    <span class="criteria-actions">
                        @if (_confirmingDeleteId == criterion.Id)
                        {
                            <button type="button" class="danger sm" aria-label="Confirm delete criterion @criterion.Name" @onclick="() => DeleteAsync(criterion)">Delete</button>
                            <button type="button" class="secondary sm" @onclick="() => _confirmingDeleteId = null">Keep</button>
                        }
                        else
                        {
                            <button class="secondary sm" @onclick="() => StartEdit(criterion)">Edit</button>
                            <button type="button" class="danger sm" aria-label="Delete criterion @criterion.Name" @onclick="() => _confirmingDeleteId = criterion.Id">✕</button>
                        }
                    </span>
                </div>
                <span class="score-cell">
                    <span class="progress"><i style="width:@(Math.Min(criterion.Weight * 2, 100))%"></i></span>
                    <strong>@criterion.Weight%</strong>
                </span>
            </div>
        }
    </div>
}

@code {
    private List<EvaluationCriterion> _criteria = new();
    private EvaluationCriterion? _editing;
    private string? _error;
    private string _selectedTemplate = "FirstTimeBuyer";
    private int _totalWeight;
    private bool _confirmingTemplate;
    private int? _confirmingDeleteId;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _criteria = (await CriteriaRepository.GetAllAsync()).ToList();
        _totalWeight = _criteria.Sum(c => c.Weight);
    }

    private void StartAdd()
    {
        _error = null;
        _editing = new EvaluationCriterion { Name = "", Weight = 10 };
    }

    private void StartEdit(EvaluationCriterion criterion)
    {
        _error = null;
        // Edit a copy so slider drags (and Cancel) never mutate the stored object.
        _editing = new EvaluationCriterion
        {
            Id = criterion.Id,
            Name = criterion.Name,
            Description = criterion.Description,
            Weight = criterion.Weight,
            Category = criterion.Category,
            ScoreAnchorLow = criterion.ScoreAnchorLow,
            ScoreAnchorMidLow = criterion.ScoreAnchorMidLow,
            ScoreAnchorMid = criterion.ScoreAnchorMid,
            ScoreAnchorMidHigh = criterion.ScoreAnchorMidHigh,
            ScoreAnchorHigh = criterion.ScoreAnchorHigh,
            IsSystemSuggested = criterion.IsSystemSuggested,
            IsWeightLocked = criterion.IsWeightLocked,
            DisplayOrder = criterion.DisplayOrder,
            CreatedAt = criterion.CreatedAt,
            UpdatedAt = criterion.UpdatedAt
        };
    }

    private async Task SaveAsync()
    {
        if (_editing == null) return;
        if (string.IsNullOrWhiteSpace(_editing.Name))
        {
            _error = "Please name the criterion.";
            return;
        }
        if (_editing.Weight is < 1 or > 50)
        {
            _error = "Weight must be between 1 and 50%.";
            return;
        }

        if (_editing.Id == 0)
        {
            _editing.DisplayOrder = _criteria.Count;
            await CriteriaRepository.CreateAsync(_editing);
        }
        else
        {
            await CriteriaRepository.UpdateAsync(_editing);
        }

        _editing = null;
        _error = null;
        await LoadAsync();
    }

    private async Task DeleteAsync(EvaluationCriterion criterion)
    {
        _confirmingDeleteId = null;
        await CriteriaRepository.DeleteAsync(criterion.Id);
        await LoadAsync();
    }

    private async Task RebalanceAsync()
    {
        var criteria = _criteria.ToList();
        var result = WeightBalancingService.Rebalance(criteria);
        if (result.Success)
        {
            foreach (var criterion in criteria)
            {
                await CriteriaRepository.UpdateAsync(criterion);
            }
        }
        await LoadAsync();
    }

    private async Task OnApplyTemplateClick()
    {
        if (_criteria.Count > 0)
        {
            _confirmingTemplate = true;
        }
        else
        {
            await ApplyTemplateAsync();
        }
    }

    private async Task ApplyTemplateAsync()
    {
        foreach (var existing in await CriteriaRepository.GetAllAsync())
        {
            await CriteriaRepository.DeleteAsync(existing.Id);
        }

        var template = HomeBuyerHelper.Core.Data.CommonCriteria.Templates[_selectedTemplate];
        var order = 0;
        foreach (var entry in template)
        {
            await CriteriaRepository.CreateAsync(new EvaluationCriterion
            {
                Name = entry.Name,
                Description = entry.Description,
                Weight = (int)entry.SuggestedWeight,
                ScoreAnchorLow = entry.ScoreAnchorLow,
                ScoreAnchorHigh = entry.ScoreAnchorHigh,
                IsSystemSuggested = true,
                DisplayOrder = order++
            });
        }

        _confirmingTemplate = false;
        await LoadAsync();
    }
}
