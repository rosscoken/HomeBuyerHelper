@page "/budget"
@inject IIncomeRepository IncomeRepository
@inject IExpenseRepository ExpenseRepository
@inject IOneTimeEventRepository EventRepository
@inject IUserPreferencesRepository PreferencesRepository
@inject IIncomeScenarioService IncomeScenarioService
@inject ICashFlowProjectionService ProjectionService
@inject IPlanService PlanService

<PageTitle>Budget · HomeBuyerHelper</PageTitle>

<h1>Budget Planner</h1>
<p class="page-sub">Income scenarios, expenses, and a month-by-month cash flow projection.</p>

<div class="grid-2">
    <div class="card">
        <h2>Income Sources</h2>
        <div class="preset-row" aria-label="Common income sources">
            @foreach (var preset in IncomePresets)
            {
                var current = preset;
                <button type="button" @onclick="() => ApplyIncomePreset(current)">@current.Name</button>
            }
        </div>
        <form class="row mt-12" @onsubmit="AddIncomeAsync" @onsubmit:preventDefault>
            <span><label>Name</label><input @bind="_newIncome.Name" /></span>
            <span>
                <label>Amount</label>
                <input type="number" @bind="_newIncome.GrossAmount" @bind:event="oninput" />
                @if (_newIncome.GrossAmount >= 10_000) { <span class="money-hint">= @_newIncome.GrossAmount.ToString("C0")</span> }
            </span>
            <span>
                <label>Frequency</label>
                <select @bind="_newIncome.Frequency">
                    @foreach (var frequency in Enum.GetValues<IncomeFrequency>())
                    {
                        <option value="@frequency">@frequency</option>
                    }
                </select>
            </span>
            <span>
                <label>Guaranteed?</label>
                <input type="checkbox" @bind="_newIncome.IsReliable" />
            </span>
            <button type="submit" class="sm">Add</button>
        </form>
        @if (_income.Count > 0)
        {
            <div class="score-list">
                @foreach (var source in _income)
                {
                    <div class="score-item">
                        <div class="score-item-head">
                            <strong>@source.Name</strong>
                            <span class="badge brand">@source.MonthlyGrossIncome.ToString("C0")/mo</span>
                            @if (source.IsReliable)
                            {
                                <span class="badge ok">Guaranteed</span>
                            }
                            else
                            {
                                <span class="badge warn">Variable (@source.Probability.ToString("F0")%)</span>
                            }
                            <span class="item-actions">
                                <button type="button" class="danger sm" aria-label="Delete income source @source.Name" @onclick="() => DeleteIncomeAsync(source)">✕</button>
                            </span>
                        </div>
                    </div>
                }
            </div>
        }
        <p class="muted mb-0">
            Monthly by scenario — Conservative: <strong>@_conservative.ToString("C0")</strong> ·
            Realistic: <strong>@_realistic.ToString("C0")</strong> ·
            Expected: <strong>@_expected.ToString("C0")</strong>
        </p>
    </div>

    <div class="card">
        <h2>Expenses</h2>
        <div class="preset-row expense-picks" aria-label="Common expenses">
            @foreach (var preset in ExpensePresets)
            {
                var current = preset;
                <button type="button" @onclick="() => ApplyExpensePreset(current)">@current.Name</button>
            }
        </div>
        <form class="row mt-12" @onsubmit="AddExpenseAsync" @onsubmit:preventDefault>
            <span><label>Name</label><input @bind="_newExpense.Name" /></span>
            <span>
                <label>Amount/mo</label>
                <input type="number" @bind="_newExpense.Amount" @bind:event="oninput" />
                @if (_newExpense.Amount >= 10_000) { <span class="money-hint">= @_newExpense.Amount.ToString("C0")</span> }
            </span>
            <span>
                <label>Variable?</label>
                <input type="checkbox" @bind="_newExpense.IsVariable" />
            </span>
            <span>
                <label>Ends at purchase?</label>
                <input type="checkbox" @bind="_newExpense.EndsAtPurchase" />
            </span>
            <button type="submit" class="sm">Add</button>
        </form>
        @if (_expenses.Count > 0)
        {
            <div class="score-list">
                @foreach (var expense in _expenses)
                {
                    <div class="score-item">
                        <div class="score-item-head">
                            <strong>@expense.Name</strong>
                            <span class="badge brand">@expense.MonthlyAmount.ToString("C0")/mo</span>
                            <span class="chip">@(expense.IsVariable ? "Variable" : "Fixed")</span>
                            @if (expense.EndsAtPurchase)
                            {
                                <span class="chip">Ends at purchase</span>
                            }
                            <span class="item-actions">
                                <button type="button" class="danger sm" aria-label="Delete expense @expense.Name" @onclick="() => DeleteExpenseAsync(expense)">✕</button>
                            </span>
                        </div>
                    </div>
                }
            </div>
        }
        <p class="muted mb-0">Total: <strong>@_expenses.Sum(e => e.MonthlyAmount).ToString("C0")/mo</strong></p>
    </div>
</div>

<div class="card">
    <h2>One-Time Events &amp; Emergency Fund</h2>
    <form class="row" @onsubmit="AddEventAsync" @onsubmit:preventDefault>
        <span><label>Event</label><input @bind="_newEvent.Name" /></span>
        <span>
            <label>Amount</label>
            <input type="number" @bind="_newEvent.Amount" @bind:event="oninput" />
            @if (_newEvent.Amount >= 10_000) { <span class="money-hint">= @_newEvent.Amount.ToString("C0")</span> }
        </span>
        <span><label>Month</label><input type="month" @bind="_eventMonth" /></span>
        <button type="submit" class="sm">Add Event</button>
    </form>
    @if (_events.Count > 0)
    {
        <div class="inline-list">
            @foreach (var budgetEvent in _events)
            {
                <span class="chip">
                    @budgetEvent.Name · @budgetEvent.Amount.ToString("C0") · @budgetEvent.Date.ToString("MMM yyyy")
                    <button type="button" aria-label="Delete event @budgetEvent.Name" @onclick="() => DeleteEventAsync(budgetEvent)">✕</button>
                </span>
            }
        </div>
    }
    <form class="row mt-12" @onsubmit="SaveFundAsync" @onsubmit:preventDefault>
        <span>
            <label>Emergency fund balance</label>
            <input type="number" @bind="_fundBalance" @bind:event="oninput" />
            @if (_fundBalance >= 10_000) { <span class="money-hint">= @_fundBalance.ToString("C0")</span> }
        </span>
        <span><label>Target (months of expenses)</label><input type="number" @bind="_fundMonths" /></span>
        <button type="submit" class="secondary sm">Save Fund</button>
    </form>
</div>

@if (_plan != null)
{
    <div class="callout">
        <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span>
            Projection includes <strong>@_plan.Property.Nickname</strong> at
            <strong>@_plan.Evaluation.TotalMonthlyCost.ToString("C0")/mo</strong> starting
            <input type="month" @bind="_purchaseMonth" @bind:after="OnPurchaseMonthChangedAsync" />
            — offer '<strong>@_plan.Offer.Name</strong>'.
            Expenses marked 'ends at purchase' stop then.
        </span>
    </div>
}

<h2>
    24-Month Cash Flow
    <span class="seg">
        <button type="button" class="@(_scenario == IncomeScenario.Conservative ? "on" : "")" @onclick="() => SetScenarioAsync(IncomeScenario.Conservative)">Conservative</button>
        <button type="button" class="@(_scenario == IncomeScenario.Realistic ? "on" : "")" @onclick="() => SetScenarioAsync(IncomeScenario.Realistic)">Realistic</button>
        <button type="button" class="@(_scenario == IncomeScenario.Expected ? "on" : "")" @onclick="() => SetScenarioAsync(IncomeScenario.Expected)">Expected</button>
    </span>
</h2>

@if (_projection.Count > 0)
{
    var last = _projection[^1];
    var firstCrunch = _projection.FirstOrDefault(m => m.IsCrunchMonth);
    <div class="stat-strip">
        <div class="stat">
            <span class="v @(last.Surplus < 0 ? "neg" : "pos")">@last.Surplus.ToString("C0")</span>
            <span class="k">Monthly surplus@(_plan != null ? " after buying" : "")</span>
        </div>
        <div class="stat">
            <span class="v @(firstCrunch != null ? "neg" : "")">@(firstCrunch?.Month.ToString("MMM yyyy") ?? "None")</span>
            <span class="k">First crunch month</span>
        </div>
        <div class="stat">
            <span class="v @(last.CumulativeSurplus < 0 ? "neg" : "")">@last.CumulativeSurplus.ToString("C0")</span>
            <span class="k">Saved over 24 months</span>
        </div>
        <div class="stat">
            <span class="v @(last.EmergencyFundWarning ? "neg" : "")">@last.EmergencyFundBalance.ToString("C0")</span>
            <span class="k">Emergency fund at end</span>
        </div>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr><th>Month</th><th class="num">Income</th><th class="num">Expenses</th><th class="num">Surplus</th><th class="num">Cumulative</th><th class="num">Emergency Fund</th></tr>
            </thead>
            <tbody>
                @foreach (var month in (_showAllMonths ? _projection : _projection.Take(6)))
                {
                    <tr>
                        <td>
                            <strong>@month.Month.ToString("MMM yyyy")</strong>
                            @if (month.IsCrunchMonth) { <span class="badge warn ml-8">Crunch</span> }
                        </td>
                        <td class="num">@month.TotalIncome.ToString("C0")</td>
                        <td class="num">@month.TotalExpenses.ToString("C0")</td>
                        <td class="num @(month.Surplus < 0 ? "neg" : "pos")">@month.Surplus.ToString("C0")</td>
                        <td class="num">@month.CumulativeSurplus.ToString("C0")</td>
                        <td class="num @(month.EmergencyFundWarning ? "neg" : "")">@month.EmergencyFundBalance.ToString("C0")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (_projection.Count > 6)
    {
        <button type="button" class="secondary sm" @onclick="() => _showAllMonths = !_showAllMonths">
            @(_showAllMonths ? "Show first 6 months" : $"Show all {_projection.Count} months")
        </button>
    }
}

@code {
    private List<IncomeSource> _income = new();
    private List<Expense> _expenses = new();
    private List<OneTimeEvent> _events = new();
    private IReadOnlyList<MonthlyProjection> _projection = Array.Empty<MonthlyProjection>();

    private IncomeSource _newIncome = NewIncome();
    private Expense _newExpense = NewExpense();
    private OneTimeEvent _newEvent = NewEvent();
    private DateTime _eventMonth = DateTime.Today;
    private decimal _fundBalance;
    private int _fundMonths = 6;
    private IncomeScenario _scenario = IncomeScenario.Realistic;
    private bool _showAllMonths;

    private decimal _conservative;
    private decimal _realistic;
    private decimal _expected;

    private PlanSnapshot? _plan;
    private DateTime _purchaseMonth = FirstOfNextMonth();

    private static DateTime FirstOfNextMonth()
    {
        var next = DateTime.Today.AddMonths(1);
        return new DateTime(next.Year, next.Month, 1);
    }

    private static IncomeSource NewIncome() => new() { Name = "", GrossAmount = 0, Frequency = IncomeFrequency.Monthly, IsReliable = true, Probability = 70 };
    private static Expense NewExpense() => new() { Name = "", Amount = 0 };

    /// <summary>
    /// One-tap starters for common income shapes.
    /// </summary>
    private static readonly (string Name, IncomeFrequency Frequency, bool IsReliable)[] IncomePresets =
    {
        ("Salary", IncomeFrequency.Monthly, true),
        ("Bonus", IncomeFrequency.Annually, false),
        ("RSU vest", IncomeFrequency.Quarterly, false),
        ("Side income", IncomeFrequency.Monthly, false),
        ("Partner", IncomeFrequency.Monthly, true)
    };

    private void ApplyIncomePreset((string Name, IncomeFrequency Frequency, bool IsReliable) preset)
    {
        _newIncome.Name = preset.Name;
        _newIncome.Frequency = preset.Frequency;
        _newIncome.IsReliable = preset.IsReliable;
    }

    /// <summary>
    /// One-tap starters for the expenses everyone has. Rent is marked
    /// "ends at purchase" since that's what buying replaces.
    /// </summary>
    private static readonly (string Name, bool IsVariable, bool EndsAtPurchase)[] ExpensePresets =
    {
        ("Rent", false, true),
        ("Groceries", true, false),
        ("Car", false, false),
        ("Utilities", true, false),
        ("Insurance", false, false),
        ("Dining out", true, false),
        ("Subscriptions", false, false)
    };

    private void ApplyExpensePreset((string Name, bool IsVariable, bool EndsAtPurchase) preset)
    {
        _newExpense.Name = preset.Name;
        _newExpense.IsVariable = preset.IsVariable;
        _newExpense.EndsAtPurchase = preset.EndsAtPurchase;
    }
    private static OneTimeEvent NewEvent() => new() { Name = "", Amount = 0, Date = DateTime.Today };

    protected override async Task OnInitializedAsync()
    {
        var preferences = await PreferencesRepository.GetAsync();
        _fundBalance = preferences.EmergencyFundBalance;
        _fundMonths = preferences.EmergencyFundTargetMonths;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _income = (await IncomeRepository.GetAllAsync()).ToList();
        _expenses = (await ExpenseRepository.GetAllAsync()).ToList();
        _events = (await EventRepository.GetAllAsync()).ToList();

        _plan = await PlanService.GetSnapshotAsync();
        if (_plan != null)
        {
            _purchaseMonth = _plan.TargetPurchaseMonth is DateTime month
                ? new DateTime(month.Year, month.Month, 1)
                : FirstOfNextMonth();
        }

        _conservative = Math.Round(IncomeScenarioService.GetAverageMonthlyIncome(_income, IncomeScenario.Conservative), 0);
        _realistic = Math.Round(IncomeScenarioService.GetAverageMonthlyIncome(_income, IncomeScenario.Realistic), 0);
        _expected = Math.Round(IncomeScenarioService.GetAverageMonthlyIncome(_income, IncomeScenario.Expected), 0);

        await ProjectAsync();
    }

    private async Task SetScenarioAsync(IncomeScenario scenario)
    {
        _scenario = scenario;
        await ProjectAsync();
    }

    private async Task ProjectAsync()
    {
        var preferences = await PreferencesRepository.GetAsync();
        _projection = ProjectionService.Project(new CashFlowProjectionInput
        {
            IncomeSources = _income,
            Expenses = _expenses,
            OneTimeEvents = _events,
            Scenario = _scenario,
            EmergencyFund = new EmergencyFundConfig
            {
                TargetMonths = preferences.EmergencyFundTargetMonths,
                CurrentBalance = preferences.EmergencyFundBalance
            },
            PlannedHousing = _plan != null
                ? new PlannedHousing
                {
                    MonthlyCost = _plan.Evaluation.TotalMonthlyCost,
                    StartMonth = _purchaseMonth
                }
                : null
        });
    }

    private async Task OnPurchaseMonthChangedAsync()
    {
        await PlanService.SetPurchaseMonthAsync(_purchaseMonth);
        await ProjectAsync();
    }

    private async Task AddIncomeAsync()
    {
        if (string.IsNullOrWhiteSpace(_newIncome.Name) || _newIncome.GrossAmount <= 0) return;
        await IncomeRepository.CreateAsync(_newIncome);
        _newIncome = NewIncome();
        await LoadAsync();
    }

    private async Task DeleteIncomeAsync(IncomeSource source)
    {
        await IncomeRepository.DeleteAsync(source.Id);
        await LoadAsync();
    }

    private async Task AddExpenseAsync()
    {
        if (string.IsNullOrWhiteSpace(_newExpense.Name) || _newExpense.Amount <= 0) return;
        await ExpenseRepository.CreateAsync(_newExpense);
        _newExpense = NewExpense();
        await LoadAsync();
    }

    private async Task DeleteExpenseAsync(Expense expense)
    {
        await ExpenseRepository.DeleteAsync(expense.Id);
        await LoadAsync();
    }

    private async Task AddEventAsync()
    {
        if (string.IsNullOrWhiteSpace(_newEvent.Name) || _newEvent.Amount <= 0) return;
        _newEvent.Date = _eventMonth;
        await EventRepository.CreateAsync(_newEvent);
        _newEvent = NewEvent();
        await LoadAsync();
    }

    private async Task DeleteEventAsync(OneTimeEvent budgetEvent)
    {
        await EventRepository.DeleteAsync(budgetEvent.Id);
        await LoadAsync();
    }

    private async Task SaveFundAsync()
    {
        var preferences = await PreferencesRepository.GetAsync();
        preferences.EmergencyFundBalance = _fundBalance;
        preferences.EmergencyFundTargetMonths = _fundMonths;
        await PreferencesRepository.SaveAsync(preferences);
        await ProjectAsync();
    }
}
