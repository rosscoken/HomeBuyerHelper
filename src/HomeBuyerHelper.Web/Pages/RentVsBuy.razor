@page "/rent-vs-buy"
@inject IRentVsBuyService RentVsBuyService
@inject IUserPreferencesRepository PreferencesRepository

<PageTitle>Rent vs Buy · HomeBuyerHelper</PageTitle>

<h1>Rent vs. Buy</h1>
<p class="page-sub">Year-by-year wealth comparison: home equity vs. renting and investing the difference.</p>

<div class="card">
    <div class="row">
        <span><label>Purchase Price</label><input type="number" @bind="_price" /></span>
        <span><label>Current Rent/mo</label><input type="number" @bind="_rent" /></span>
        <span><label>Other Ownership Costs/mo</label><input type="number" @bind="_ownershipCosts" /></span>
    </div>
    <div class="row mt-12">
        <span><label>Down Payment %</label><input type="number" step="1" @bind="_downPaymentPercent" /></span>
        <span><label>Rate %</label><input type="number" step="0.125" @bind="_interestRate" /></span>
        <span>
            <label>Term</label>
            <select @bind="_mortgageTerm">
                <option value="15">15 years</option>
                <option value="20">20 years</option>
                <option value="30">30 years</option>
            </select>
        </span>
    </div>
    <div class="row mt-12">
        <span><label>Rent Increase %/yr</label><input type="number" step="0.1" @bind="_rentIncrease" /></span>
        <span><label>Investment Return %/yr</label><input type="number" step="0.1" @bind="_investReturn" /></span>
        <span><label>Appreciation %/yr</label><input type="number" step="0.1" @bind="_appreciation" /></span>
        <span><label>Horizon (years)</label><input type="number" min="1" max="30" @bind="_horizon" /></span>
    </div>
    <div class="row mt-14">
        <button @onclick="CompareAsync">
            <svg aria-hidden="true" focusable="false" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            Compare
        </button>
    </div>
    <p class="muted mt-12 mb-0">Defaults come from Settings — <a href="settings">edit</a></p>
    @if (_error != null) { <p class="error-text">@_error</p> }
</div>

@if (_result != null && _result.Years.Count > 0)
{
    <div class="verdict-card">
        <h2>@_verdict</h2>
        <p>Monthly cost of owning in year one: @_result.InitialMonthlyOwnershipCost.ToString("C0")</p>
    </div>

    <div class="table-wrap">
        <table>
            <thead>
                <tr><th>Year</th><th class="num">Buy Net Wealth</th><th class="num">Rent Net Wealth</th><th style="text-align:center">Ahead</th></tr>
            </thead>
            <tbody>
                @foreach (var year in _result.Years)
                {
                    <tr>
                        <td><strong>@year.Year</strong></td>
                        <td class="num">@year.BuyNetWealth.ToString("C0")</td>
                        <td class="num">@year.RentNetWealth.ToString("C0")</td>
                        <td style="text-align:center">
                            <span class="badge @(year.BuyingIsAhead ? "ok" : "warn")">@(year.BuyingIsAhead ? "Buy" : "Rent")</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private decimal _price;
    private decimal _rent;
    private decimal _ownershipCosts = 800m;
    private decimal _downPaymentPercent;
    private decimal _interestRate;
    private int _mortgageTerm;
    private decimal _rentIncrease = 3m;
    private decimal _investReturn = 7m;
    private decimal _appreciation = 3m;
    private int _horizon = 10;
    private string? _error;
    private string _verdict = "";
    private RentVsBuyResult? _result;

    protected override async Task OnInitializedAsync()
    {
        var preferences = await PreferencesRepository.GetAsync();
        _downPaymentPercent = preferences.DefaultDownPaymentPercent;
        _interestRate = preferences.DefaultInterestRate;
        _mortgageTerm = preferences.DefaultMortgageTerm;
    }

    private void CompareAsync()
    {
        if (_price <= 0 || _rent <= 0)
        {
            _error = "Enter a purchase price and your current rent.";
            return;
        }

        _error = null;

        _result = RentVsBuyService.Compare(new RentVsBuyInput
        {
            PurchasePrice = _price,
            DownPaymentPercent = _downPaymentPercent,
            InterestRate = _interestRate,
            MortgageTermYears = _mortgageTerm,
            MonthlyOwnershipCosts = _ownershipCosts,
            CurrentMonthlyRent = _rent,
            AnnualRentIncreasePercent = _rentIncrease,
            InvestmentReturnPercent = _investReturn,
            HomeAppreciationPercent = _appreciation,
            HorizonYears = Math.Clamp(_horizon, 1, 30)
        });

        _verdict = _result.BreakevenYear is int year
            ? $"Buying pulls ahead in year {year} — {_result.FinalAdvantage:C0} ahead after {_horizon} years."
            : $"Renting stays ahead for the full {_horizon}-year horizon ({Math.Abs(_result.FinalAdvantage):C0} better).";
    }
}
